#!/bin/bash
# save-deliverable <agent-name> <filename>
# Reads from stdin and writes to the audit directory

set -e

AGENT_NAME="${1:?Usage: save-deliverable <agent-name> <filename>}"
FILENAME="${2:?Usage: save-deliverable <agent-name> <filename>}"

AUDIT_DIR="${PENTEM_AUDIT_DIR:-/workspace/audit}"
DEL_DIR="$AUDIT_DIR/$AGENT_NAME/deliverables"

mkdir -p "$DEL_DIR"

# Cap at 2MB
dd bs=1024 count=2048 of="$DEL_DIR/$FILENAME" 2>/dev/null

echo "Saved deliverable: $DEL_DIR/$FILENAME"
