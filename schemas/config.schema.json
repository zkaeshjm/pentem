{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shannon Configuration",
  "type": "object",
  "required": ["target"],
  "properties": {
    "target": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Target application URL"
        },
        "auth": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["form", "sso", "apikey", "basic"],
              "description": "Authentication type"
            },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "totpSecret": { "type": "string" },
            "loginUrl": { "type": "string", "format": "uri" },
            "apiKeyHeader": { "type": "string" },
            "apiKeyValue": { "type": "string" },
            "cookieString": { "type": "string" }
          },
          "required": ["type"]
        },
        "focus": {
          "type": "object",
          "properties": {
            "include": {
              "type": "array",
              "items": { "type": "string" }
            },
            "exclude": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "properties": {
        "retryPreset": {
          "type": "string",
          "enum": ["default", "fast", "subscription"],
          "default": "default"
        },
        "maxConcurrent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3
        }
      }
    },
    "provider": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["anthropic", "bedrock", "vertex", "custom"]
        }
      }
    },
    "models": {
      "type": "object",
      "properties": {
        "small": { "type": "string" },
        "medium": { "type": "string" },
        "large": { "type": "string" }
      }
    }
  }
}
